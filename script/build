#!/bin/bash
#
# Builds one (or more executable).
#
# Usage:
#   Just your native executable:
#      ./script/build
#   All cross compile platforms:
#      ./script/build all

set -euo pipefail

export CGO_ENABLED=0 # Force static compiling

declare -r progname="temple"
version="$(git describe --tags || echo unreleased)"
declare -r version
declare -r ldflags="-s -w -X main.version=${version}"

go build \
  -v \
  -ldflags "$ldflags" \
  -o "$progname" \
  ./...

# vim: set ft=sh :
